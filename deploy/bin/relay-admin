#!/usr/bin/env bash
set -euo pipefail

readonly RELAY_SYSTEMD_UNIT="local-api-relay.service"
readonly SYSTEMCTL_BIN="${SYSTEMCTL_BIN:-/usr/bin/systemctl}"

usage() {
  cat >&2 <<'EOF'
Usage: relay-admin <status|restart>

Restricted admin entry for the relay system service.
EOF
}

if [ "$#" -ne 1 ]; then
  usage
  exit 64
fi

case "$1" in
  status)
    exec "$SYSTEMCTL_BIN" --no-pager --full status "$RELAY_SYSTEMD_UNIT"
    ;;
  restart)
    "$SYSTEMCTL_BIN" restart "$RELAY_SYSTEMD_UNIT"
    exec "$SYSTEMCTL_BIN" --no-pager --full status "$RELAY_SYSTEMD_UNIT"
    ;;
  *)
    usage
    exit 64
    ;;
esac
