{
  "server": {
    "listen_host": "127.0.0.1",
    "listen_port": 8787,
    "admin_key": "change-me-admin-key",
    "database_path": "state/local_api_relay.sqlite3",
    "idle_window_seconds": 300,
    "request_timeout_seconds": 120
  },
  "local": {
    "clients": [
      {
        "client_id": "chatbox",
        "local_key": "local-chatbox-key"
      }
    ]
  },
  "upstreams": {
    "primary-openai": {
      "base_url": "https://api.openai.com/v1",
      "api_key": "sk-primary-upstream-key",
      "enabled": true,
      "transport": {
        "timeout_seconds": 120
      }
    },
    "backup-openai": {
      "base_url": "https://api.openai.com/v1",
      "api_key": "sk-backup-upstream-key",
      "enabled": true,
      "transport": {
        "timeout_seconds": 120
      }
    }
  },
  "order": [
    "primary-openai",
    "backup-openai"
  ],
  "pricing": {
    "currency": "USD",
    "upstreams": {
      "primary-openai": {
        "input_per_million_tokens": 0.5,
        "output_per_million_tokens": 1.5,
        "models": {
          "gpt-5-mini": {
            "input_per_million_tokens": 0.25,
            "output_per_million_tokens": 1.0
          }
        }
      },
      "backup-openai": {
        "input_per_million_tokens": 0.6,
        "output_per_million_tokens": 1.8
      }
    }
  }
}
